# .streamlit/secrets.toml
# For Streamlit Cloud deployment — add these in your app's Secrets settings
# DO NOT commit this file to GitHub!

BACKEND_URL = "https://your-backend.onrender.com"

# These are only needed if running the backend on Streamlit Cloud too
# (not recommended — use Render for backend)
# GEMINI_API_KEY = "your_key"
# SUPABASE_URL = "your_url"
# SUPABASE_KEY = "your_key"
